{
  "presets": [
    [
      "@babel/preset-env",
      { "modules": false }
    ],
    [
      "@babel/preset-react",
      {
        "throwIfNamespace": false,
        "runtime": "automatic",
        "targets": {
          "chrome": "120"
        },
        "importSource": "@local/jsx"
      }
    ]
  ],
  "plugins": [
    ["module-resolver", {
      "root": ["../"],
      "alias": {
        "@local/jsx/jsx-runtime": "../dev_modules/@local/jsx/jsx-runtime.js"
      }
    }]
  ],
  "sourceMaps": true
}